{
  "name": "dnd-combat",
  "version": "0.1.0",
  "description": "Grid-based D&D 5.5e combat simulator",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/ui/cli/main.ts",
    "campaign": "tsx src/ui/cli/campaign.ts",
    "arena": "tsx scripts/arena.ts",
    "web": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:typecheck": "tsc -p web/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.6",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
